# Database (PostgreSQL)
# For local dev: use Prisma Postgres (npx prisma dev) or a local PostgreSQL instance
DATABASE_URL="postgresql://user:password@localhost:5432/glorybank?schema=public"

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET="your-super-secret-jwt-key-min-64-chars-long-change-this-in-production"

# Asaas API (sandbox for testing)
# Get your key at: https://sandbox.asaas.com → Configurações → Integrações → API
ASAAS_API_KEY="your-asaas-sandbox-api-key"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
# Production: https://api.asaas.com/api/v3

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"

# ─────────────────────────────────────────────────────────────
# DEMO MODE — set to "true" to run the app without a real
# PostgreSQL database or Asaas API key.
#
# In demo mode:
#   • All API routes return mock/sandbox data
#   • Login works with: demo@glorybank.com / Demo@123456
#   • Registration is disabled (use the demo account)
#   • No data is persisted between requests
#
# Perfect for: portfolio demos, local exploration, testing UI
# ─────────────────────────────────────────────────────────────
DEMO_MODE=true

# Demo mode — set to true to run without a real database or Asaas account
# Use credentials: demo@glorybank.com / Demo@123456
DEMO_MODE="false"
