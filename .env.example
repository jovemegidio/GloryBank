# ─────────────────────────────────────────────────────────────────────────────
# CredBusiness — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de executar.
# NUNCA comite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# ── OBRIGATÓRIO ──────────────────────────────────────────────────────────────

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/credbusiness?schema=public"

# Senha usada pelo PostgreSQL no docker-compose da VPS.
# Em producao, use uma senha longa e unica.
DB_PASSWORD="ALTERE_PARA_UMA_SENHA_FORTE"

# Chave JWT — OBRIGATÓRIO em produção. Gere com: openssl rand -base64 64
JWT_SECRET="ALTERE_PARA_UMA_CHAVE_SEGURA_COM_MINIMO_64_CARACTERES"

# ── ASAAS BaaS ───────────────────────────────────────────────────────────────
# Sandbox: https://sandbox.asaas.com → Configurações → Integrações
# Produção: https://api.asaas.com/v3 (requer aprovação BaaS pelo Asaas)
ASAAS_API_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY="$aact_your_key_here"

# Token para validar webhooks enviados pelo Asaas
ASAAS_WEBHOOK_TOKEN="token-secreto-para-validar-webhooks-asaas"
ASAAS_WEBHOOK_URL="https://credbusinessbank.com.br/api/asaas/webhook"
ASAAS_WEBHOOK_EMAIL="contato@credbusinessbank.com.br"
ASAAS_AUTO_WEBHOOKS=true
# Use true somente quando a conta nao puder ser criada sem webhook registrado no Asaas.
ASAAS_REQUIRE_WEBHOOKS=false

# ── TAXAS ASAAS ──────────────────────────────────────────────────────────────
# Sobrescreva com as condições do seu contrato BaaS, se houver.
ASAAS_FEE_PIX_INCOMING="1.99"
ASAAS_FEE_PIX_INCOMING_PROMO="0.99"
ASAAS_FEE_BOLETO_INCOMING="1.99"
ASAAS_FEE_BOLETO_INCOMING_PROMO="0.99"
ASAAS_FEE_PIX_OUTGOING_PJ_FREE_MONTHLY="30"
ASAAS_FEE_PIX_OUTGOING_PJ_AFTER_FREE="2.00"
ASAAS_FEE_TED_OUTGOING="5.00"

# ── SELO ASAAS (Playbook BaaS — obrigatório) ─────────────────────────────────
# URLs fornecidas pelo Asaas após aprovação e homologação da marca.
# Enquanto não receber as URLs oficiais, o componente exibirá um placeholder.
# Referência: https://www.asaas.com/playbook-baas (acesso restrito)
NEXT_PUBLIC_ASAAS_SEAL_URL_POSITIVE=""
NEXT_PUBLIC_ASAAS_SEAL_URL_MONO_BLACK=""
NEXT_PUBLIC_ASAAS_SEAL_URL_MONO_WHITE=""
NEXT_PUBLIC_ASAAS_SEAL_REDIRECT_URL="https://www.asaas.com"
NEXT_PUBLIC_ASAAS_SEAL_ID=""

# ── MODO DEMO ────────────────────────────────────────────────────────────────
# "true" para demo sem conta Asaas real
DEMO_MODE=false

# Em HTTPS/producao, mantenha true ou omita. Use false apenas em ambiente local HTTP.
COOKIE_SECURE=true

# ── APP URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://credbusinessbank.com.br"

# ── EMPRESA ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_NAME="CredBusiness"
